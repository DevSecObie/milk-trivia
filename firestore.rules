rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'obediyah.ben.israel@gmail.com' ||
        request.auth.token.email == 'oisrae1@wgu.edu'
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users: own doc only, admins read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['displayName']);
      allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'displayName', 'xp', 'level', 'title', 'totalAnswered', 'totalCorrect',
        'streak', 'survivalBest', 'speedBest', 'achievements', 'missed',
        'questionStats', 'dailyGoal', 'dailyProgress', 'qotdHistory',
        'levelUp', 'sessions', 'settings', 'dailyGoalDays', 'updatedAt',
        'activeGame', 'sound', 'theme', 'photoURL'
      ]);
      allow delete: if isOwner(userId);
    }

    // Config (weekly challenges) — admin write, all read
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Challenge entries — own entry write, all read
    match /challengeEntries/{entryId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // Duels
    match /duels/{duelId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'waiting';
      allow update: if request.auth != null && (
        resource.data.hostUid == request.auth.uid ||
        resource.data.guestUid == request.auth.uid ||
        (resource.data.guestUid == null && resource.data.status == 'waiting')
      );
      allow delete: if request.auth != null && resource.data.hostUid == request.auth.uid;
    }
  }
}
