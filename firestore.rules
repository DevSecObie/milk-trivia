rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - authenticated users can read any profile,
    // but only write their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Duels collection - any authenticated user can create and list duels,
    // participants can read and update their own duel
    match /duels/{duelId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.hostUid
            || request.auth.uid == resource.data.guestUid
            || resource.data.guestUid == null);
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.hostUid;
    }
  }
}
